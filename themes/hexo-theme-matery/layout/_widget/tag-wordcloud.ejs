<div class="container tag-sphere-section" data-aos="fade-up">
    <div class="card">
        <div class="card-content tag-sphere-card">
            <div id="tag-sphere" class="tag-sphere" role="list" aria-label="键盘标签动态星球">
                <% site.tags.map(function(tag) { %>
                <a href="<%- url_for(tag.path) %>"
                   class="tag-sphere-item"
                   role="listitem"
                   data-weight="<%- tag.length %>"
                   title="<%- tag.name %>：<%- tag.length %> 篇文章"><%- tag.name %></a>
                <% }); %>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const sphere = document.getElementById('tag-sphere');
        if (!sphere) return;

        const items = Array.from(sphere.querySelectorAll('.tag-sphere-item'));
        if (!items.length) return;

        const goldenAngle = Math.PI * (3 - Math.sqrt(5));
        const points = items.map(function (item, index) {
            const y = items.length === 1 ? 0 : 1 - (index / (items.length - 1)) * 2;
            const horizontalRadius = Math.sqrt(Math.max(0, 1 - y * y));
            const angle = goldenAngle * index;
            return {
                index: index,
                item: item,
                x: Math.cos(angle) * horizontalRadius,
                y: y,
                z: Math.sin(angle) * horizontalRadius,
                weight: Number(item.dataset.weight) || 1
            };
        });

        const weights = points.map(function (point) { return Math.log(point.weight + 1); });
        const minWeight = Math.min.apply(null, weights);
        const maxWeight = Math.max.apply(null, weights);
        const weightRange = Math.max(1, maxWeight - minWeight);
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

        let width = 0;
        let height = 0;
        let sphereRadius = 0;
        let rotationX = -0.14;
        let rotationY = 0;
        let frameId = null;
        let lastFrame = 0;
        let isVisible = false;
        let isPaused = false;

        points.forEach(function (point, index) {
            const popularity = (weights[index] - minWeight) / weightRange;
            point.item.style.setProperty('--tag-popularity', popularity.toFixed(3));
        });

        const measure = function () {
            const bounds = sphere.getBoundingClientRect();
            width = bounds.width;
            height = bounds.height;
            sphereRadius = Math.min(width, height) * (width < 500 ? 0.32 : 0.42);
        };

        const render = function () {
            const cosY = Math.cos(rotationY);
            const sinY = Math.sin(rotationY);
            const cosX = Math.cos(rotationX);
            const sinX = Math.sin(rotationX);

            points.forEach(function (point) {
                const hiddenOnMobile = width < 500 && point.index % 2 === 1;
                point.item.hidden = hiddenOnMobile;
                if (hiddenOnMobile) return;

                const rotatedX = point.x * cosY - point.z * sinY;
                const rotatedZ = point.x * sinY + point.z * cosY;
                const rotatedY = point.y * cosX - rotatedZ * sinX;
                const depthZ = point.y * sinX + rotatedZ * cosX;
                const perspective = 3.8 / (3.8 - depthZ);
                const depth = (depthZ + 1) / 2;
                const x = width / 2 + rotatedX * sphereRadius * perspective;
                const y = height / 2 + rotatedY * sphereRadius * perspective;
                const scale = 0.5 + depth * 0.88;
                const opacity = 0.06 + Math.pow(depth, 2.15) * 0.94;
                const isFocused = point.item === document.activeElement;

                point.item.style.transform = 'translate3d(' + x.toFixed(2) + 'px, ' + y.toFixed(2) + 'px, 0) translate(-50%, -50%) scale(' + scale.toFixed(3) + ')';
                point.item.style.opacity = opacity.toFixed(3);
                point.item.style.zIndex = String(Math.round(depth * 100));
                point.item.style.pointerEvents = depth > 0.4 || isFocused ? 'auto' : 'none';
                point.item.tabIndex = depth > 0.58 || isFocused ? 0 : -1;
            });
        };

        const animate = function (time) {
            if (!isVisible || reducedMotion.matches) {
                frameId = null;
                return;
            }

            if (!lastFrame) lastFrame = time;
            const elapsed = Math.min(48, time - lastFrame);
            if (!isPaused && elapsed >= 30) {
                rotationY += elapsed * 0.00019;
                rotationX += elapsed * 0.000035;
                lastFrame = time;
                render();
            }
            frameId = requestAnimationFrame(animate);
        };

        const updateAnimation = function () {
            if (isVisible && !reducedMotion.matches && !frameId) {
                lastFrame = 0;
                frameId = requestAnimationFrame(animate);
            } else if ((!isVisible || reducedMotion.matches) && frameId) {
                cancelAnimationFrame(frameId);
                frameId = null;
            }
            render();
        };

        sphere.addEventListener('mouseenter', function () { isPaused = true; });
        sphere.addEventListener('mouseleave', function () { isPaused = false; });
        sphere.addEventListener('focusin', function () { isPaused = true; });
        sphere.addEventListener('focusout', function () { isPaused = false; });

        const visibilityObserver = new IntersectionObserver(function (entries) {
            isVisible = entries[0].isIntersecting;
            updateAnimation();
        }, { rootMargin: '100px 0px' });
        visibilityObserver.observe(sphere);

        if (typeof ResizeObserver !== 'undefined') {
            new ResizeObserver(function () {
                measure();
                render();
            }).observe(sphere);
        } else {
            window.addEventListener('resize', function () {
                measure();
                render();
            });
        }

        reducedMotion.addEventListener('change', updateAnimation);
        measure();
        render();
    })();
</script>
