<%
var configuredSlides = theme.cover && Array.isArray(theme.cover.images) ? theme.cover.images : [];
var homeSlides = configuredSlides.map(function (slide) {
    if (typeof slide === 'string') {
        return { image: slide, textTone: 'light' };
    }

    return {
        image: slide.image,
        textTone: slide.textTone === 'dark' ? 'dark' : 'light'
    };
}).filter(function (slide) {
    return slide.image;
});

if (homeSlides.length === 0) {
    homeSlides = [{ image: '/medias/banner/0.jpg', textTone: 'dark' }];
}

var initialTextTone = homeSlides[0].textTone;
%>

<div id="homeCoverCarousel"
     class="carousel carousel-slider center index-cover home-cover-carousel"
     data-indicators="<%- theme.cover.showIndicators %>"
     aria-label="首页图片轮播"
     style="margin-top: -64px;">
    <% if (homeSlides.length > 1 && theme.cover.showPrevNext) { %>
    <button id="prev-cover" class="left waves-effect carousel-control" type="button" aria-label="上一张图片">
        <i class="icon fa fa-angle-left" aria-hidden="true"></i>
    </button>
    <button id="next-cover" class="right waves-effect carousel-control" type="button" aria-label="下一张图片">
        <i class="icon fa fa-angle-right" aria-hidden="true"></i>
    </button>
    <% } %>

    <div class="home-cover-content home-cover-content--<%- initialTextTone %>-text">
        <div class="container">
            <%- partial('_partial/bg-cover-content', { homeHero: true }) %>

            <div class="cover-btns">
                <a href="<%=
                        [theme.dream, theme.music, theme.video, theme.recommend]
                                .some(function (item) { return item.enable; }) ? '#indexCard' : '#articles'
                        %>" class="waves-effect waves-light btn">
                    <i class="fa fa-angle-double-down" aria-hidden="true"></i><%- __('startRead') %>
                </a>
            </div>
        </div>
    </div>

    <% homeSlides.forEach(function (slide, index) { %>
    <div class="carousel-item bg-cover home-cover-slide home-cover-slide--<%- slide.textTone %>-text"
         data-text-tone="<%- slide.textTone %>"
         style="background-image: url('<%- theme.jsDelivr.url %><%- url_for(slide.image) %>');"
         aria-hidden="true"></div>
    <% }); %>
</div>

<script>
    $(function () {
        var coverSlider = $('#homeCoverCarousel');
        var coverContent = coverSlider.find('.home-cover-content');
        var slideCount = coverSlider.find('.home-cover-slide').length;
        var carouselIntervalId = null;
        var shouldAutoLoop = <%- theme.cover.autoLoop ? 'true' : 'false' %> && slideCount > 1;
        var intervalTime = Math.max(Number('<%- theme.cover.intervalTime %>') || 10000, 1000);

        function applyTextTone(slide) {
            var textTone = $(slide).attr('data-text-tone') === 'dark' ? 'dark' : 'light';
            coverContent
                .removeClass('home-cover-content--dark-text home-cover-content--light-text')
                .addClass('home-cover-content--' + textTone + '-text');
        }

        function stopAutoCarousel() {
            if (carouselIntervalId !== null) {
                clearInterval(carouselIntervalId);
                carouselIntervalId = null;
            }
        }

        function startAutoCarousel() {
            stopAutoCarousel();
            if (!shouldAutoLoop || document.hidden) {
                return;
            }

            carouselIntervalId = setInterval(function () {
                coverSlider.carousel('next');
            }, intervalTime);
        }

        coverSlider.carousel({
            duration: Number('<%- theme.cover.duration %>') || 520,
            fullWidth: true,
            indicators: '<%- theme.cover.showIndicators %>' === 'true',
            onCycleTo: function (slide) {
                applyTextTone(slide);
            }
        });

        applyTextTone(coverSlider.find('.home-cover-slide').first());
        startAutoCarousel();

        coverSlider.on('mousedown touchstart', stopAutoCarousel);
        $(document).on('mouseup touchend touchcancel', startAutoCarousel);
        document.addEventListener('visibilitychange', function () {
            if (document.hidden) {
                stopAutoCarousel();
            } else {
                startAutoCarousel();
            }
        });

        <% if (theme.cover.showPrevNext) { %>
        $('#prev-cover').on('click', function () {
            coverSlider.carousel('prev');
            startAutoCarousel();
        });
        $('#next-cover').on('click', function () {
            coverSlider.carousel('next');
            startAutoCarousel();
        });
        <% } %>
    });
</script>
