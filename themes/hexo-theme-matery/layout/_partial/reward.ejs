<div id="reward" class="reward-popover">
    <button type="button" class="reward-link btn-floating btn-medium waves-effect waves-light red"
            aria-controls="rewardPanel" aria-expanded="false">赏</button>

    <div id="rewardPanel" class="reward-panel" role="dialog" aria-hidden="true" aria-label="<%= theme.reward.title %>">
        <div class="reward-panel-content">
            <button type="button" class="close reward-close" aria-label="关闭打赏二维码"><i class="fas fa-times"></i></button>
            <h4 class="reward-title"><%= theme.reward.title %></h4>
            <div class="reward-content">
                <div class="reward-tabs">
                    <ul class="tabs row">
                        <li class="tab col s6 alipay-tab waves-effect waves-light"><a href="#alipay">支付宝</a></li>
                        <li class="tab col s6 wechat-tab waves-effect waves-light"><a href="#wechat">微 信</a></li>
                    </ul>
                    <div id="alipay">
                        <img src="<%- theme.jsDelivr.url %><%- url_for(theme.reward.alipay) %>" class="reward-img" alt="支付宝打赏二维码">
                    </div>
                    <div id="wechat">
                        <img src="<%- theme.jsDelivr.url %><%- url_for(theme.reward.wechat) %>" class="reward-img" alt="微信打赏二维码">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(function () {
        const reward = document.getElementById('reward');
        if (!reward) return;

        const trigger = reward.querySelector('.reward-link');
        const panel = reward.querySelector('.reward-panel');
        const closeButton = reward.querySelector('.reward-close');
        const supportsHover = window.matchMedia('(hover: hover) and (pointer: fine)');

        reward.querySelectorAll('.tabs').forEach(function (tabs) {
            $(tabs).tabs();
        });

        const setOpen = function (isOpen) {
            reward.classList.toggle('is-open', isOpen);
            trigger.setAttribute('aria-expanded', String(isOpen));
            panel.setAttribute('aria-hidden', String(!isOpen));
        };

        reward.addEventListener('mouseenter', function () {
            if (supportsHover.matches) setOpen(true);
        });
        reward.addEventListener('mouseleave', function () {
            if (supportsHover.matches) setOpen(false);
        });
        trigger.addEventListener('click', function () {
            setOpen(!reward.classList.contains('is-open'));
        });
        closeButton.addEventListener('click', function () {
            setOpen(false);
            trigger.focus();
        });
        document.addEventListener('click', function (event) {
            if (!reward.contains(event.target)) setOpen(false);
        });
        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') setOpen(false);
        });
    });
</script>
